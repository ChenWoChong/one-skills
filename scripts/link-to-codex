#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
codex_skills_dir="${CODEX_HOME:-$HOME/.codex}/skills"

mkdir -p "$codex_skills_dir"

shopt -s nullglob
for skill_dir in "$repo_root"/skills/*; do
  [[ -d "$skill_dir" ]] || continue
  name="$(basename "$skill_dir")"
  link="$codex_skills_dir/$name"

  if [[ -L "$link" ]]; then
    current="$(readlink "$link")"
    if [[ "$current" == "$skill_dir" ]]; then
      echo "已链接：$name"
      continue
    fi
    if [[ ! -e "$link" ]]; then
      rm "$link"
      ln -s "$skill_dir" "$link"
      echo "已修复失效链接：$name"
      continue
    fi
    echo "拒绝替换已有软链接：$link -> $current" >&2
    exit 1
  fi

  if [[ -e "$link" ]]; then
    echo "拒绝替换已有路径：$link" >&2
    exit 1
  fi

  ln -s "$skill_dir" "$link"
  echo "已链接：$name"
done
