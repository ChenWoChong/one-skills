#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
skill_dirs=(
  "$HOME/.agents/skills"
  "${CODEX_HOME:-$HOME/.codex}/skills"
)

link_skill() {
  local skill_dir="$1"
  local target_dir="$2"
  local name link current

  name="$(basename "$skill_dir")"
  link="$target_dir/$name"

  mkdir -p "$target_dir"

  if [[ -L "$link" ]]; then
    current="$(readlink "$link")"
    if [[ "$current" == "$skill_dir" ]]; then
      echo "已链接：$link"
      return
    fi
    if [[ ! -e "$link" ]]; then
      rm "$link"
      ln -s "$skill_dir" "$link"
      echo "已修复失效链接：$link"
      return
    fi
    echo "拒绝替换已有软链接：$link -> $current" >&2
    exit 1
  fi

  if [[ -e "$link" ]]; then
    echo "拒绝替换已有路径：$link" >&2
    exit 1
  fi

  ln -s "$skill_dir" "$link"
  echo "已链接：$link"
}

shopt -s nullglob
for skill_dir in "$repo_root"/skills/*; do
  [[ -d "$skill_dir" ]] || continue
  for target_dir in "${skill_dirs[@]}"; do
    link_skill "$skill_dir" "$target_dir"
  done
done
