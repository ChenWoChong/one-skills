#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
failed=0

shopt -s nullglob
for skill_dir in "$repo_root"/skills/*; do
  [[ -d "$skill_dir" ]] || continue
  name="$(basename "$skill_dir")"
  skill_file="$skill_dir/SKILL.md"

  if [[ ! "$name" =~ ^[a-z0-9-]+$ ]]; then
    echo "skill 目录名不合法：$name" >&2
    failed=1
  fi

  if [[ ! -f "$skill_file" ]]; then
    echo "缺少 SKILL.md：$name" >&2
    failed=1
    continue
  fi

  declared_name="$(awk '
    NR == 1 && $0 != "---" { exit 1 }
    NR > 1 && $0 == "---" { exit }
    NR > 1 && /^name:[[:space:]]*/ {
      sub(/^name:[[:space:]]*/, "")
      gsub(/^"|"$/, "")
      print
      exit
    }
  ' "$skill_file")"

  description="$(awk '
    NR == 1 && $0 != "---" { exit 1 }
    NR > 1 && $0 == "---" { exit }
    NR > 1 && /^description:[[:space:]]*/ {
      sub(/^description:[[:space:]]*/, "")
      gsub(/^"|"$/, "")
      print
      exit
    }
  ' "$skill_file")"

  if [[ "$declared_name" != "$name" ]]; then
    echo "$skill_file 中的 name 不匹配：期望 $name，实际 ${declared_name:-<missing>}" >&2
    failed=1
  fi

  if [[ -z "$description" ]]; then
    echo "$skill_file 缺少 description" >&2
    failed=1
  fi
done

if [[ "$failed" -ne 0 ]]; then
  exit "$failed"
fi

echo "所有 skills 校验通过"
